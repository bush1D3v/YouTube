      "link": null,
      "locked": false,
      "text": "function calculateMedia(items) {\n     const totalPrice = calculateTotal(items);\n     const totalItems = items.length;\n\n     return totalPrice / totalItems;\n}\n",
      "fontSize": 27.099385499011856,
      "fontFamily": 7,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "function calculateMedia(items) {\n     const totalPrice = calculateTotal(items);\n     const totalItems = items.length;\n\n     return totalPrice / totalItems;\n}\n",
      "autoResize": true,
      "lineHeight": 1.15
    },
